#######################################
# Acceptance Runner
#######################################
ACCEPTANCE_TARGET=local
ACCEPTANCE_PROFILE=full
ACCEPTANCE_BASE_URL=http://127.0.0.1:5000
ACCEPTANCE_S3_ENDPOINT=http://127.0.0.1:5000/s3
ACCEPTANCE_TUS_ENDPOINT=http://127.0.0.1:5000/upload/resumable
ACCEPTANCE_X_FORWARDED_HOST=
ACCEPTANCE_REGION=us-east-1
ACCEPTANCE_RESOURCE_PREFIX=acc-local
# Matches the default dummy-data tenant; change this for non-default seeds or remote targets.
ACCEPTANCE_TENANT_ID=bjhaohmqunupljrqypxz
ACCEPTANCE_ALLOW_DESTRUCTIVE=false
# Managed local runs admin acceptance only when the spawned server is multitenant.
ACCEPTANCE_ENABLE_ADMIN=true
ACCEPTANCE_ADMIN_URL=http://127.0.0.1:5001
ACCEPTANCE_ENABLE_CDN=true
# Local render acceptance needs imgproxy to reach source objects.
# For S3-backed local runs, set STORAGE_S3_PRIVATE_ASSET_ENDPOINT
# in the server env, not in this acceptance-runner env file.
ACCEPTANCE_ENABLE_RENDER=true
# RLS acceptance self-provisions read objects under ACCEPTANCE_RLS_WRITE_PREFIX unless
# ACCEPTANCE_RLS_READ_OBJECT points at an existing object readable by authenticated role.
ACCEPTANCE_ENABLE_RLS_SETUP=true
# ACCEPTANCE_RLS_READ_OBJECT=authenticated/casestudy.png
# Vector acceptance requires a configured S3 Vectors-compatible service.
ACCEPTANCE_ENABLE_VECTOR=false
ACCEPTANCE_ENABLE_ICEBERG=true
ACCEPTANCE_ENABLE_WIRE=true
ACCEPTANCE_ENABLE_TUS=true
ACCEPTANCE_S3_FORCE_PATH_STYLE=true

#######################################
