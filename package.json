    "@biomejs/biome": "^2.4.4",
    "@types/async-retry": "^1.4.5",
    "@types/busboy": "^1.3.0",
    "@types/cloneable-readable": "^2.0.3",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.5",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.6.4",
    "@types/stream-buffers": "^3.0.7",
    "@types/xml2js": "^0.4.14",
    "babel-jest": "^30.3.0",
    "esbuild": "^0.25.8",
    "form-data": "^4.0.0",
