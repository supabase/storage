  },
  "version": "1.11.2",
  "description": "Supabase Storage Service",
  "main": "index.js",
  "author": "Supabase",
  "license": "ISC",
  "bin": "./dist/server.js",
  "engines": {
    "node": ">=24.0.0"
  }
}
